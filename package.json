{
  "name": "airchive",
  "version": "0.1.0",
  "private": true,
  "description": "BSV blockchain aircraft telemetry platform — immutable flight data recording",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:e2e": "pnpm --filter dashboard run test:e2e",
    "clean": "pnpm -r run clean",
    "db:migrate": "pnpm --filter @airchive/db run migrate:latest",
    "db:rollback": "pnpm --filter @airchive/db run migrate:rollback",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "track-list:opensky": "node scripts/fetch-tracked-aircraft-from-opensky.mjs"
  }
}
