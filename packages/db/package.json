{
  "name": "@airchive/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "migrate:latest": "knex migrate:latest --knexfile src/knexfile.ts",
    "migrate:rollback": "knex migrate:rollback --knexfile src/knexfile.ts",
    "migrate:make": "knex migrate:make --knexfile src/knexfile.ts"
  },
  "dependencies": {
    "knex": "^3.1.0",
    "pg": "^8.13.0",
    "@airchive/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "rimraf": "^6.0.0"
  }
}
