  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/express": "^5.0.0",
    "@types/ws": "^8.5.0",
    "knex": "^3.1.0",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "rimraf": "^6.0.0"
  }
