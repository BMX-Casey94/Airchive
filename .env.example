# === Airchive Environment Configuration ===

# --- Node ---
NODE_ENV=development
LOG_LEVEL=debug

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=airchive
POSTGRES_USER=airchive
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- BSV Blockchain ---
BSV_NETWORK=mainnet
TAAL_ARC_URL=https://arc.taal.com
TAAL_ARC_API_KEY=CHANGE_ME
WOC_API_URL=https://api.whatsonchain.com/v1/bsv/main
# ARC pressure shaping
ARC_MAX_CONCURRENT_BROADCASTS=80
ARC_MAX_QUEUE_DEPTH=640
# Additional retries after the initial transient failure attempt
ARC_TRANSIENT_RETRY_ATTEMPTS=0
ARC_TRANSIENT_RETRY_BASE_MS=250
ARC_CIRCUIT_FAILURE_THRESHOLD=64
ARC_CIRCUIT_WINDOW_MS=10000
ARC_CIRCUIT_OPEN_MS=5000

# --- Wallet Vault ---
# BIP39 mnemonic for HD wallet master seed (store in HSM/Vault in production)
WALLET_MASTER_SEED=CHANGE_ME_NEVER_COMMIT_THIS
# Funding wallet private key WIF (for auto-refill operations)
FUNDING_WALLET_WIF=CHANGE_ME

# --- Data Sources ---
# adsb.fi is the primary source (free, no API key, rich data)
ADSBFI_API_URL=https://opendata.adsb.fi/api/v2
# OpenSky is disabled by default (credit-based, limited data fields)
OPENSKY_ENABLED=false
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
OPENSKY_API_URL=https://opensky-network.org/api
RTL_SDR_ENDPOINT=http://localhost:8080/data/aircraft.json
RTL_SDR_ENABLED=false

# --- Ingestion ---
POLL_INTERVAL_MS=1000
# Comma-separated ICAO hex codes of aircraft to track. Ingestion calls adsb.fi
# GET /hex/{csv} in batches of 20 per poll (see services/ingestion/src/clients/adsbfi.ts);
# each extra ~20 hex codes adds another HTTP request per cycle. The dashboard WebSocket
# only relays Redis pub/sub to subscribers — it does not download a global ADS-B snapshot.
# Generate candidate lists: node scripts/fetch-tracked-aircraft-from-opensky.mjs --max 200
TRACKED_AIRCRAFT=4076E8,407798,4072C7,4072C8,407131,4077D3,4CA242,4CA568,43C6B8,43C6F3,43C6F9,43C918,43C919,43C5EB,43C61D
# Demo replay: publishes recorded telemetry to Redis (no live ADS-B polling)
DEMO_MODE=false
# Optional; when unset, uses services/ingestion dist (or src) data/demo-flights.json next to the module
DEMO_REPLAY_PATH=
DEMO_SPEED_MULTIPLIER=1

# --- Gateway ---
GATEWAY_PORT=4000
GATEWAY_WS_PORT=4001
JWT_SECRET=CHANGE_ME_IN_PRODUCTION
JWT_EXPIRY=24h
CORS_ORIGIN=http://localhost:3000

# --- Overlay Node ---
OVERLAY_PORT=4010
OVERLAY_TOPIC=tm_airchive

# --- Alert Engine ---
ALERT_ENGINE_PORT=4020
SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
ALERT_EMAIL_TO=
ALERT_SMS_TO=

# --- Auto-refill ---
ARC_CALLBACK_PORT=9092
REFILL_THRESHOLD_SATS=5000
REFILL_AMOUNT_SATS=10000
# Keep active aircraft pre-warmed with multiple spendable outputs to avoid single-UTXO bottlenecks
ACTIVE_AIRCRAFT_UTXO_TARGET=8
# Refill fan-out will not create outputs smaller than this value
REFILL_MIN_OUTPUT_SATS=10000
# Skip auto-refill for aircraft with no write activity within this window (ms, default 30 min)
REFILL_IDLE_WINDOW_MS=1800000

# --- Agent Marketplace ---
# Private keys for agent wallets (auto-generated on first run if empty; persist for stable addresses)
COLLECTOR_AGENT_KEY=
ANALYST_AGENT_KEY=
MONITOR_AGENT_KEY=
AGENT_ANALYSIS_INTERVAL_MS=30000
AGENT_MONITOR_INTERVAL_MS=5000
AGENT_METRICS_PORT=9093
BSV_STORAGE_URL=https://storage.babbage.systems

# --- Dashboard ---
NEXT_PUBLIC_GATEWAY_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4001/ws
NEXT_PUBLIC_CESIUM_ION_TOKEN=CHANGE_ME
